# Safe local/CI Django test configuration. Never use production credentials.
# The test settings module requires the database name prefix below.
TEST_DB_NAME=financee_test_local
TEST_DB_USER=postgres
TEST_DB_PASSWORD=test-only-password
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_MAINTENANCE_NAME=postgres

# Base settings load these before test_settings replaces the database config.
SECRET_KEY=test-only-secret-key-not-for-production
DEBUG=False
DB_NAME=do_not_use
DB_USER=do_not_use
DB_PASSWORD=do_not_use
DB_HOST=do_not_use
DB_PORT=5432
REDIS_URL=
