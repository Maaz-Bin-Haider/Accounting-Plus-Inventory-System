# Test-only image. Coverage and future CI tools never enter the production image.
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt requirements-test.txt ./
RUN pip install --no-cache-dir -r requirements-test.txt

COPY . .

RUN chmod +x scripts/run_django_tests.sh

CMD ["scripts/run_django_tests.sh"]
