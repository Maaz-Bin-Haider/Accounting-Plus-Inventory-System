# Template for the .env file. Copy to .env and fill in real values.
# The .env file is read by both docker-compose.yml (db credentials) and
# Django (django-environ). Never commit the real .env to git.

# Security
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Comma-separated. Keep the elastic IP; add a domain later if you get one.
ALLOWED_HOSTS=13.232.33.250,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://13.232.33.250

# Keep these disabled until Cloudflare Full (strict) and nginx origin TLS are
# verified. Then enable them together; HSTS should be the final step.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
TRUST_X_FORWARDED_PROTO=False

# Database (DB_HOST/DB_PORT are overridden to db:5432 inside docker compose;
# the values here are used when running Django outside docker)
DB_NAME=financee
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=localhost
DB_PORT=5432

# Redis cache (overridden to redis://redis:6379/1 inside docker compose).
# Leave empty to disable Redis and fall back to in-process memory cache.
REDIS_URL=

# How long dashboard API responses are cached in Redis, in seconds.
# 0 disables dashboard caching entirely.
DASHBOARD_CACHE_SECONDS=60
